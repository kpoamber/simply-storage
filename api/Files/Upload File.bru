meta {
  name: Upload File
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/api/projects/{{projectId}}/files
  body: multipartForm
  auth: bearer
}

auth:bearer {
  token: {{access_token}}
}

body:multipart-form {
  file: @file(./sample.txt)
}

script:post-response {
  if (res.status === 201) {
    bru.setVar("fileId", res.body.id);
  }
}
