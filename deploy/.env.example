# =============================================================================
# Innovare Storage - Production Environment Variables
# Copy this file to .env and fill in the values
# =============================================================================

# --- Docker Image ---
# GHCR registry and image name (set automatically by CI, override if needed)
IMAGE_REGISTRY=ghcr.io
IMAGE_NAME=your-org/innovare-storage
IMAGE_TAG=latest

# --- Database ---
POSTGRES_USER=innovare
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=innovare_storage
DB_MAX_CONNECTIONS=10

# --- Application Auth ---
JWT_SECRET=CHANGE_ME_RANDOM_JWT_SECRET_AT_LEAST_32_CHARS
ADMIN_USERNAME=admin
ADMIN_PASSWORD=CHANGE_ME_ADMIN_PASSWORD

# --- Application Settings ---
HMAC_SECRET=CHANGE_ME_RANDOM_HMAC_SECRET
RUST_LOG=info
SYNC_NUM_WORKERS=4
SYNC_MAX_RETRIES=5
SYNC_POLL_INTERVAL=5
TIER_SCAN_INTERVAL=300

# --- Network ---
HTTP_PORT=80
HTTPS_PORT=443
DOMAIN=storage.example.com

# --- TLS / Certbot ---
CERTBOT_EMAIL=admin@example.com

# --- Backup ---
BACKUP_RETENTION_DAYS=30
BACKUP_SCHEDULE=0 2 * * *
