# =============================================================================
# Innovare Storage - Production Environment Variables
# Copy this file to .env and fill in the values
# =============================================================================

# --- Docker Image ---
# GHCR registry and image name (set automatically by CI, override if needed)
IMAGE_REGISTRY=ghcr.io
IMAGE_NAME=your-org/innovare-storage
IMAGE_TAG=latest

# --- Database ---
POSTGRES_USER=innovare
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=innovare_storage
DB_MAX_CONNECTIONS=10

# --- Application Auth ---
JWT_SECRET=CHANGE_ME_RANDOM_JWT_SECRET_AT_LEAST_32_CHARS
ADMIN_USERNAME=admin
ADMIN_PASSWORD=CHANGE_ME_ADMIN_PASSWORD

# --- Application Settings ---
HMAC_SECRET=CHANGE_ME_RANDOM_HMAC_SECRET
RUST_LOG=info
SYNC_NUM_WORKERS=4
SYNC_MAX_RETRIES=5
SYNC_POLL_INTERVAL=5
TIER_SCAN_INTERVAL=300

# --- Network ---
HTTP_PORT=80
HTTPS_PORT=443
DOMAIN=storage.example.com

# --- TLS / Certbot ---
# NOTE: Not wired automatically. After deploy, run manually on server:
# docker compose exec certbot certbot certonly --webroot -w /var/www/certbot -d $DOMAIN --email $CERTBOT_EMAIL --agree-tos
CERTBOT_EMAIL=admin@example.com

# --- Deployment ---
DEPLOY_PROFILE=small

# --- Backup (script-based, deploy/scripts/backup.sh) ---
# Schedule is defined in .github/workflows/backup.yml (cron triggers GHA, not local cron).
BACKUP_RETENTION_DAYS=30

# --- In-App Backup Worker ---
APP_BACKUP__ENABLED=true
APP_BACKUP__CHECK_INTERVAL_SECS=60

# --- Resumable (tus) uploads ---
# Chunk size suggested to clients; keep under the Cloudflare 100 MB body limit.
APP_UPLOAD__CHUNK_SIZE=50331648
# Lifetime of an in-progress upload session before cleanup (seconds).
APP_UPLOAD__SESSION_TTL_SECS=86400
# Max total size for a single resumable upload in bytes (0 = unlimited).
APP_UPLOAD__MAX_FILE_SIZE=0
# How often the cleanup worker sweeps abandoned sessions (seconds).
APP_UPLOAD__CLEANUP_INTERVAL_SECS=3600

# --- Dashboard ---
# How long file_access_events are kept before being pruned (days, 0 = forever).
APP_DASHBOARD__EVENTS_RETENTION_DAYS=365
